# ──────────────────────────────────────────────
# Automated Test Validation System
# Environment Variables
# ──────────────────────────────────────────────

# REQUIRED — Groq API key (get one free at https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_api_key_here

# OPTIONAL — Override the default LLM model
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MODEL=mixtral-8x7b-32768

# OPTIONAL — WebDriver Manager caching
# Skip online ChromeDriver version check; re-check after N days
# WDM_CHECK_DRIVER_VERSION=false
# WDM_CACHE_VALID_RANGE=7
