# ──────────────────────────────────────────────
# Automated Test Validation System
# Environment Variables
# ──────────────────────────────────────────────

# ── Regular agents LLM ──────────────────────────
# Used by: analyst, script_writer, executor, self_healer, reporter, explorer
LLM_PROVIDER=cerebras
LLM_MODEL=gpt-oss-120b

# ── API Keys (only fill the one you use) ────────
GROQ_API_KEY=your_groq_key_here
CEREBRAS_API_KEY=your_cerebras_key_here
# LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1

# ── Browser Use vision LLM (must support vision/multimodal) ─
# Used by tools/browser_use_runner.py for captcha & 2FA
# Also used by the Explorer for vision-based page intelligence
BROWSER_USE_PROVIDER=groq
BROWSER_USE_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
BROWSER_USE_API_KEY=your_groq_key_here
# BROWSER_USE_BASE_URL=https://api.groq.com/openai/v1

# ── Download directory for Selenium ─────────────
# Where Chrome saves file downloads during test execution
# DOWNLOAD_DIR=outputs/downloads

# ── 2FA / TOTP ─────────────────────────────────
# TOTP_SECRET=your_totp_secret_here

# ── WebDriver Manager caching ──────────────────
# WDM_CHECK_DRIVER_VERSION=false
# WDM_CACHE_VALID_RANGE=7
