# ──────────────────────────────────────────────
# Automated Test Validation System
# Environment Variables
# ──────────────────────────────────────────────

# ── LLM Provider ────────────────────────────────
# Supported: groq | lmstudio | cerebras
LLM_PROVIDER=groq

# ── Model Name ──────────────────────────────────
# Pick a model that matches your provider:
#   Groq:     llama-3.3-70b-versatile, meta-llama/llama-4-scout-17b-16e-instruct
#   LM Studio: meta-llama-3.1-8b-instruct  (whatever you loaded locally)
#   Cerebras:  llama-3.3-70b
LLM_MODEL=llama-3.3-70b-versatile

# ── API Keys (only fill the one you use) ────────
# Groq (free at https://console.groq.com/keys)
GROQ_API_KEY=your_groq_key_here

# Cerebras
# CEREBRAS_API_KEY=your_cerebras_key_here

# LM Studio — no API key needed (runs locally)
# LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1

# ── WebDriver Manager caching ──────────────────
# Skip online ChromeDriver version check; re-check after N days
# WDM_CHECK_DRIVER_VERSION=false
# WDM_CACHE_VALID_RANGE=7
